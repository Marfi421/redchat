{
  "name": "redchat",
  "version": "1.0.3",
  "description": "RedChat",
  "author": "Marfi",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win portable",
    "publish": "electron-builder --win portable --publish always"
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "express": "^4.18.2",
    "socket.io": "^4.7.2"
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "redchat.app",
    "productName": "RedChat",
    "asar": true,
    "files": [
      "**/*"
    ],
    "win": {
      "target": "portable",
      "icon": "icon.png"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "Marfi421",
        "repo": "redchat"
      }
    ]
  }
}
